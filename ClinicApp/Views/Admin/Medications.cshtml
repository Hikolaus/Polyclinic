@model List<ClinicApp.Models.Core.Medication>
@{
    ViewData["Title"] = "Справочник лекарств";
}

<div class="container mt-4">
    <h2><i class="fas fa-pills me-2"></i>Справочник лекарств</h2>

    <div class="card mb-4 mt-3 border-success">
        <div class="card-header bg-success text-white">Добавить новое лекарство</div>
        <div class="card-body">
            <form action="/Admin/AddMedication" method="post" class="row g-3">
                <div class="col-md-4">
                    <input type="text" name="Name" class="form-control" placeholder="Название (напр. Аспирин)" required>
                </div>
                <div class="col-md-3">
                    <input type="text" name="Form" class="form-control" placeholder="Форма (напр. Таблетки)" required>
                </div>
                <div class="col-md-3">
                    <input type="text" name="Manufacturer" class="form-control" placeholder="Производитель">
                </div>
                <div class="col-md-2 d-flex align-items-center">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="PrescriptionRequired" value="true" id="presCheck">
                        <label class="form-check-label" for="presCheck">По рецепту</label>
                    </div>
                </div>
                <div class="col-12 text-end">
                    <button type="submit" class="btn btn-success">Добавить</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Название</th>
                        <th>Форма</th>
                        <th>Производитель</th>
                        <th>Доступ</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in Model)
                    {
                        <tr>
                            <td class="fw-bold">@m.Name</td>
                            <td>@m.Form</td>
                            <td>@m.Manufacturer</td>
                            <td>
                                @if (m.PrescriptionRequired)
                                {
                                    <span class="badge bg-danger">Рецепт</span>
                                }
                                else
                                {

                                    <span class="badge bg-success">Свободно</span>
                                }
                            </td>
                            <td class="text-end">
                                <form action="/Admin/DeleteMedication" method="post" onsubmit="return confirm('Удалить?');">
                                    <input type="hidden" name="id" value="@m.Id" />
                                    <button class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>