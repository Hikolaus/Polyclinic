@model List<ClinicApp.Models.Core.Specialization>
@{
    ViewData["Title"] = "Специализации";
}

<div class="container mt-4">
    <h2><i class="fas fa-briefcase-medical me-2"></i>Специализации врачей</h2>

    <div class="card mb-4 mt-3 border-info">
        <div class="card-header bg-info text-white">Добавить специализацию</div>
        <div class="card-body">
            <form action="/Admin/AddSpecialization" method="post" class="row g-3">
                <div class="col-md-5">
                    <input type="text" name="Name" class="form-control" placeholder="Название (напр. Уролог)" required>
                </div>
                <div class="col-md-5">
                    <input type="text" name="Description" class="form-control" placeholder="Описание">
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-info w-100 text-white">Добавить</button>
                </div>
            </form>
        </div>
    </div>

    <div class="list-group shadow-sm">
        @foreach (var s in Model)
        {
            <div class="list-group-item d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="mb-0">@s.Name</h6>
                    <small class="text-muted">@s.Description</small>
                </div>
                <span class="badge bg-light text-dark border">@s.AverageConsultationTime мин</span>
            </div>
        }
    </div>
</div>