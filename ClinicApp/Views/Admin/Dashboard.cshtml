@{
    ViewData["Title"] = "Панель администратора";
}

<div class="container-fluid mt-3">
    <h2 class="mb-4"><i class="fas fa-chart-line me-2"></i>Панель управления</h2>

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-white bg-primary shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title text-uppercase mb-0 opacity-75">Пациенты</h6>
                            <h2 class="my-2 display-6 fw-bold">@ViewBag.TotalPatients</h2>
                        </div>
                        <i class="fas fa-users fa-3x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-success shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title text-uppercase mb-0 opacity-75">Врачи</h6>
                            <h2 class="my-2 display-6 fw-bold">@ViewBag.TotalDoctors</h2>
                        </div>
                        <i class="fas fa-user-md fa-3x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-warning shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title text-uppercase mb-0 opacity-75">Всего записей</h6>
                            <h2 class="my-2 display-6 fw-bold text-dark">@ViewBag.TotalAppointments</h2>
                        </div>
                        <i class="fas fa-calendar-check fa-3x text-dark opacity-25"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold">Динамика записей (последние 14 дней)</h5>
                </div>
                <div class="card-body">
                    <canvas id="appointmentsChart" height="100"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold">Популярность направлений</h5>
                </div>
                <div class="card-body">
                    <canvas id="specsChart" height="200"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>

    const ctx1 = document.getElementById('appointmentsChart').getContext('2d');
    new Chart(ctx1, {
        type: 'line',
        data: {
            labels: @Html.Raw(Json.Serialize(ViewBag.Dates)),
            datasets: [{
                label: 'Количество записей',
                data: @Html.Raw(Json.Serialize(ViewBag.DateCounts)),
                borderColor: '#3498db',
                backgroundColor: 'rgba(52, 152, 219, 0.1)',
                tension: 0.3,
                fill: true
            }]
        }
    });

    const ctx2 = document.getElementById('specsChart').getContext('2d');
    new Chart(ctx2, {
        type: 'doughnut',
        data: {
            labels: @Html.Raw(Json.Serialize(ViewBag.SpecLabels)),
            datasets: [{
                data: @Html.Raw(Json.Serialize(ViewBag.SpecData)),
                backgroundColor: [
                    '#2ecc71', '#3498db', '#9b59b6', '#f1c40f', '#e74c3c', '#95a5a6'
                ]
            }]
        }
    });
</script>